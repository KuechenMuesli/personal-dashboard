{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "personal-dashboard",
  "compatibility_date": "2026-04-10",
  "main": ".svelte-kit/cloudflare/_worker.js",
  "assets": {
    "binding": "ASSETS",
    "directory": ".svelte-kit/cloudflare"
  },
  "observability": {
    "enabled": true
  }
}
